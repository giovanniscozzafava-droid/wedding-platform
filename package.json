{
  "name": "wedding-platform",
  "private": true,
  "version": "0.1.0",
  "description": "Wedding Platform MVP - capostipiti, fornitori, calendario, preventivi",
  "type": "module",
  "scripts": {
    "dev": "npm --prefix frontend run dev",
    "build": "npm --prefix frontend run build",
    "lint": "npm --prefix frontend run lint",
    "test": "npm --prefix frontend run test --silent --run",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:reset": "supabase db reset",
    "db:status": "supabase status",
    "db:types": "supabase gen types typescript --local --schema public 2>/dev/null | grep -vE '^Connecting to db|^A new version|^We recommend updating' > frontend/src/lib/database.types.ts",
    "db:diff": "supabase db diff",
    "scenario": "RUN_STRESS=1 playwright test tests/e2e/realistic_scenario.spec.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@supabase/supabase-js": "^2.106.1",
    "dotenv": "^16.6.1"
  }
}
